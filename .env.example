MISTRAL_API_KEY=your_mistral_api_key_here

# ---------------------------------------------------------------------------
# LLM provider configuration (model-agnostic support)
# ---------------------------------------------------------------------------
# LLM_PROVIDER selects which API provider to use for formalization, classification,
# explanation, and assumption detection. The agentic proving loop always uses
# Mistral's Conversations API regardless of this setting; for alternative agentic
# backends, register a custom prover via prover_backend.register_prover().
#
# Supported values: mistral (default), openai, anthropic
# LLM_PROVIDER=mistral

# LLM_MODEL overrides the model name for the selected provider.
# Defaults: mistral → labs-leanstral-2603, openai → gpt-4o, anthropic → claude-3-5-sonnet-20241022
# LLM_MODEL=labs-leanstral-2603

# API keys for alternative providers (only required when using that provider)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# API server configuration
# ---------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins, or * to allow all (default).
# Examples: https://myapp.vercel.app,https://staging.myapp.com
# ALLOWED_ORIGINS=*
